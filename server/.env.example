# ---- Supabase (Project Settings -> API) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # secret. backend only. never ship to frontend.

# Alternative: use a direct Supabase Postgres connection string instead of SUPABASE_SERVICE_KEY.
# Keep this backend-only and never expose it to the frontend.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# ---- Groq (console.groq.com -> API Keys). Free tier is fine. ----
GROQ_API_KEY=your-groq-key
# Pick a current chat model from https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Notion (notion.so/my-integrations). Optional — sync only. ----
NOTION_TOKEN=
# Filled in by `npm run setup-notion`, or paste your existing database IDs:
NOTION_DAILY_DB_ID=2e302ed1fc144d7cbb8bfa6e3456182d
NOTION_QUESTIONS_DB_ID=df41cceb1b1b407d9f2ad63f66c2de2a
NOTION_APPLICATIONS_DB_ID=38771ee06ca541e79f4c1389b155bd37
NOTION_SPEAKING_DB_ID=cde6d8121cb84d919f6c7c1dc69715cb
# STAR Stories Bank — fill in manually via Notion, no auto-sync (you write these):
# https://app.notion.com/p/95274fbc57cd494091bc1db61841d5d8
# A Notion page ID the integration can write to (used only by setup-notion):
NOTION_PARENT_PAGE_ID=

# ---- App ----
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
APP_PASSCODE=change-me              # simple shared secret; frontend sends it. keep it private.
PLAN_START_DATE=2026-06-17          # day 1 of your 90-day plan
TIMEZONE=Asia/Kolkata
